<script>
let chartInstance = null;

const presets = {
  robojob: {investment:95000,operators:1.5,wage:30,hours:1840,uptime:4200,productivity:12,scrap:4000,maintenance:3200,energy:1800,interest:0,depreciation:7,'sick-days':10,'temp-cost':200,'lost-production':400,recruitment:2500},
  cmz:     {investment:140000,operators:2,wage:27,hours:1840,uptime:5500,productivity:8,scrap:6000,maintenance:5000,energy:2500,interest:2.5,depreciation:8,'sick-days':11,'temp-cost':210,'lost-production':450,recruitment:3000},
  trumpf:  {investment:210000,operators:2.5,wage:32,hours:1840,uptime:5000,productivity:20,scrap:12000,maintenance:7000,energy:3500,interest:3,depreciation:10,'sick-days':12,'temp-cost':240,'lost-production':600,recruitment:3500}
};

function loadPreset(key) {
  ['robojob','cmz','trumpf'].forEach(k => document.getElementById('preset-'+k).classList.remove('active'));
  document.getElementById('preset-'+key).classList.add('active');
  const p = presets[key];
  Object.keys(p).forEach(k => { const el = document.getElementById(k); if(el) el.value = p[k]; });
  calc();
}

function v(id) { return parseFloat(document.getElementById(id).value) || 0; }

function fmt(n, dec=0) {
  return new Intl.NumberFormat('de-DE', {minimumFractionDigits:dec, maximumFractionDigits:dec}).format(
    Math.round(n * Math.pow(10,dec)) / Math.pow(10,dec)
  );
}

function calc() {
  const investment      = v('investment');
  const operators       = v('operators');
  const wage            = v('wage');
  const hours           = v('hours');
  const productivity    = v('productivity');
  const scrap           = v('scrap');
  const maintenance     = v('maintenance');
  const energy          = v('energy');
  const interest        = v('interest');

  const laborSavings    = operators * wage * hours;
  const productivityGain = laborSavings * (productivity / 100);
  const annualCosts     = maintenance + energy;
  const annualInterest  = investment * (interest / 100);

  const sickDays        = v('sick-days');
  const tempCost        = v('temp-cost');
  const lostProd        = v('lost-production');
  const recruitment     = v('recruitment');
  const absenceCost     = operators * sickDays * tempCost;
  const lostProdTotal   = operators * sickDays * lostProd;
  const recruitTotal    = operators * recruitment;
  const hiddenCost      = absenceCost + lostProdTotal + recruitTotal;

  const annualNetSavings = laborSavings + productivityGain + scrap + hiddenCost - annualCosts - annualInterest;

  const costPerOp     = wage * hours;
  const totalLabour   = operators * costPerOp;
  const costPerHour   = operators > 0 && hours > 0 ? totalLabour / (operators * hours) : 0;
  const robotHours    = v('uptime');
  const robotVsLabour = totalLabour > 0 ? ((investment / 7) / totalLabour * 100) : 0;
  const N = n => new Intl.NumberFormat('de-DE').format(Math.round(n));

  const fi = (id, val) => { const el = document.getElementById(id); if(el) el.textContent = val; };
  fi('fi-cost-per-op',    '€' + N(costPerOp));
  fi('fi-total-labour',   '€' + N(totalLabour));
  fi('fi-cost-per-hour',  '€' + costPerHour.toFixed(2));
  fi('fi-absence-cost',   '€' + N(absenceCost));
  fi('fi-lost-prod',      '€' + N(lostProdTotal));
  fi('fi-recruitment',    '€' + N(recruitTotal));
  fi('fi-hidden-cost',    '€' + N(hiddenCost));
  fi('fi-robot-hours',    N(robotHours) + ' h/yr');
  fi('fi-robot-vs-labour', totalLabour > 0 ? robotVsLabour.toFixed(0) + '% of labour cost/yr' : '—');
  fi('fi-labour-savings', '€' + N(laborSavings + hiddenCost));

  const panel = document.getElementById('results-panel');

  if (annualNetSavings <= 0 || investment <= 0) {
    panel.innerHTML = `
      <div class="error-state">
        <div class="err-icon">⚠</div>
        <p>Net savings are zero or negative with current inputs.<br>Adjust labour costs, investment amount, or productivity gains.</p>
      </div>`;
    if (chartInstance) { chartInstance.destroy(); chartInstance = null; }
    return;
  }

  const paybackYears    = investment / annualNetSavings;
  const roi             = (annualNetSavings / investment) * 100;
  const savings5        = annualNetSavings * 5 - investment;
  const savings10       = annualNetSavings * 10 - investment;
  const breakEvenMonth  = Math.ceil(paybackYears * 12);
  const pbYrs           = Math.floor(paybackYears);
  const pbMths          = Math.round((paybackYears - pbYrs) * 12);
  const pbLabel         = pbYrs > 0 ? `${pbYrs}y ${pbMths}m` : `${Math.round(paybackYears*12)}m`;

  panel.innerHTML = `
    <div class="kpi-bar">
      <div class="kpi-card hero">
        <div class="kpi-label">Payback period</div>
        <div class="kpi-value">${pbLabel}</div>
        <div class="kpi-sub">Break-even: month ${breakEvenMonth}</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">Annual ROI</div>
        <div class="kpi-value" style="color:${roi>=25?'var(--green)':roi>=12?'var(--text)':'var(--red)'}">${fmt(roi,1)}%</div>
        <div class="kpi-sub">${roi>=25?'Excellent':'roi>=12?Good':'Review costs'}</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">Annual net savings</div>
        <div class="kpi-value">€${fmt(annualNetSavings)}</div>
        <div class="kpi-sub">After all costs</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">Labour savings</div>
        <div class="kpi-value">€${fmt(laborSavings)}</div>
        <div class="kpi-sub">${fmt(operators,1)} FTE × ${fmt(wage)}€/h</div>
      </div>
    </div>

    <div class="breakdown-card">
      <div class="card-header">
        Annual savings breakdown
        <span style="color:var(--accent);font-family:var(--font-mono);font-size:12px">€${fmt(annualNetSavings)} net</span>
      </div>
      <div class="breakdown-rows">
        <div class="brow positive">
          <span class="brow-label">Labour savings</span>
          <span class="brow-val">+€${fmt(laborSavings)}</span>
        </div>
        <div class="brow positive">
          <span class="brow-label">Productivity gain (${productivity}%)</span>
          <span class="brow-val">+€${fmt(productivityGain)}</span>
        </div>
        <div class="brow positive">
          <span class="brow-label">Scrap reduction</span>
          <span class="brow-val">+€${fmt(scrap)}</span>
        </div>
        <div class="brow-divider"></div>
        <div class="brow negative">
          <span class="brow-label">Maintenance & energy</span>
          <span class="brow-val">−€${fmt(annualCosts)}</span>
        </div>
        ${annualInterest > 0 ? `<div class="brow negative"><span class="brow-label">Financing cost</span><span class="brow-val">−€${fmt(annualInterest)}</span></div>` : ''}
        <div class="brow-divider"></div>
        <div class="brow total">
          <span class="brow-label">Annual net savings</span>
          <span class="brow-val">€${fmt(annualNetSavings)}</span>
        </div>
      </div>
    </div>

    <div class="chart-card">
      <div class="card-header">Cumulative savings vs. investment</div>
      <div class="chart-body">
        <div class="chart-legend">
          <div class="legend-item"><div class="legend-dot" style="background:#d4f04e"></div>Net cumulative gain</div>
          <div class="legend-item"><div class="legend-dot" style="background:#ff5f5f;opacity:.6"></div>Investment baseline</div>
        </div>
        <div class="chart-canvas-wrap">
          <canvas id="roiChart" role="img" aria-label="Line chart showing cumulative savings vs investment over 10 years. Break-even at month ${breakEvenMonth}.">Cumulative net savings over 10 years, break-even at month ${breakEvenMonth}.</canvas>
        </div>
      </div>
    </div>

    <div class="longterm-grid">
      <div class="lt-card">
        <div>
          <div class="lt-label">Net gain</div>
          <div class="lt-value">€${fmt(savings5)}</div>
        </div>
        <div class="lt-year-badge">5Y</div>
      </div>
      <div class="lt-card">
        <div>
          <div class="lt-label">Net gain</div>
          <div class="lt-value">€${fmt(savings10)}</div>
        </div>
        <div class="lt-year-badge">10Y</div>
      </div>
    </div>

    <button class="export-btn" onclick="exportSummary()">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M7 1v8M4 6l3 3 3-3M2 11h10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Export summary as .txt
    </button>`;

  renderChart(annualNetSavings, investment, breakEvenMonth);
}

function renderChart(annualNetSavings, investment, breakEvenMonth) {
  if (chartInstance) { chartInstance.destroy(); chartInstance = null; }
  const labels = [], cumData = [], invLine = [];
  for (let m = 0; m <= 120; m += 3) {
    labels.push(m === 0 ? '0' : m % 12 === 0 ? `${m/12}y` : `${m}m`);
    cumData.push(Math.round((annualNetSavings / 12) * m - investment));
    invLine.push(-investment);
  }
  const ctx = document.getElementById('roiChart');
  if (!ctx) return;
  chartInstance = new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [
        {
          label: 'Net cumulative gain',
          data: cumData,
          borderColor: '#d4f04e',
          backgroundColor: 'rgba(212,240,78,0.06)',
          fill: true,
          tension: 0.35,
          pointRadius: 0,
          borderWidth: 2
        },
        {
          label: 'Investment',
          data: invLine,
          borderColor: 'rgba(255,95,95,0.5)',
          borderDash: [4, 4],
          pointRadius: 0,
          borderWidth: 1.5,
          fill: false
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: '#23252e',
          borderColor: 'rgba(255,255,255,0.08)',
          borderWidth: 1,
          titleColor: '#9a9b9f',
          bodyColor: '#f0f0ee',
          padding: 10,
          callbacks: {
            label: ctx => `${ctx.dataset.label}: €${new Intl.NumberFormat('de-DE').format(ctx.parsed.y)}`
          }
        }
      },
      scales: {
        x: {
          grid: { color: 'rgba(255,255,255,0.04)' },
          ticks: { font: { family: 'DM Mono', size: 10 }, color: '#5c5e65', maxTicksLimit: 11, autoSkip: true }
        },
        y: {
          grid: { color: 'rgba(255,255,255,0.04)' },
          ticks: {
            font: { family: 'DM Mono', size: 10 },
            color: '#5c5e65',
            callback: v => `€${new Intl.NumberFormat('de-DE', {notation:'compact'}).format(v)}`
          }
        }
      }
    }
  });
}

function exportSummary() {
  const investment      = v('investment');
  const operators       = v('operators');
  const wage            = v('wage');
  const hours           = v('hours');
  const productivity    = v('productivity');
  const scrap           = v('scrap');
  const maintenance     = v('maintenance');
  const energy          = v('energy');
  const interest        = v('interest');
  const depreciation    = v('depreciation');

  const laborSavings    = operators * wage * hours;
  const productivityGain = laborSavings * (productivity / 100);
  const annualCosts     = maintenance + energy;
  const annualInterest  = investment * (interest / 100);
  const hiddenCost      = operators * v('sick-days') * v('temp-cost') + operators * v('sick-days') * v('lost-production') + operators * v('recruitment');
  const annualNetSavings = laborSavings + productivityGain + scrap + hiddenCost - annualCosts - annualInterest;
  const paybackYears    = annualNetSavings > 0 ? investment / annualNetSavings : null;
  const roi             = annualNetSavings > 0 ? (annualNetSavings / investment) * 100 : null;
  const savings5        = annualNetSavings * 5 - investment;
  const savings10       = annualNetSavings * 10 - investment;
  const breakEvenMonth  = paybackYears ? Math.ceil(paybackYears * 12) : '-';
  const pbYrs           = paybackYears ? Math.floor(paybackYears) : '-';
  const pbMths          = paybackYears ? Math.round((paybackYears - Math.floor(paybackYears)) * 12) : '-';

  const Nf = n => new Intl.NumberFormat('de-DE').format(Math.round(n));

  const text = `╔══════════════════════════════════════════════╗
║       AUTOMATION ROI SUMMARY REPORT          ║
╚══════════════════════════════════════════════╝
Generated:  ${new Date().toLocaleDateString('en-GB', {day:'2-digit',month:'long',year:'numeric'})}

── INVESTMENT ─────────────────────────────────
  Total investment:            €${Nf(investment)}
  Depreciation period:         ${depreciation} years

── LABOUR ─────────────────────────────────────
  Operators replaced:          ${operators} FTE
  Hourly wage (loaded):        €${Nf(wage)}/h
  Working hours/year:          ${Nf(hours)} h/yr

── MISSING OPERATOR COSTS ─────────────────────
  Sick/absent days/yr:         ${v('sick-days')} days/operator
  Temp cover cost:             €${Nf(v('temp-cost'))}/day
  Lost production/day:         €${Nf(v('lost-production'))}/day
  Recruitment (annualised):    €${Nf(v('recruitment'))}/operator/yr

── ANNUAL SAVINGS ─────────────────────────────
  Labour savings:             +€${Nf(laborSavings)}
  Hidden operator costs:      +€${Nf(hiddenCost)}
  Productivity gain (${productivity}%):     +€${Nf(productivityGain)}
  Scrap reduction:            +€${Nf(scrap)}
  Maintenance & energy:       -€${Nf(annualCosts)}
  Financing cost:             -€${Nf(annualInterest)}
  ──────────────────────────────────────────────
  NET ANNUAL SAVINGS:          €${Nf(annualNetSavings)}

── RESULTS ────────────────────────────────────
  Payback period:              ${pbYrs}y ${pbMths}m
  Break-even at month:         ${breakEvenMonth}
  Annual ROI:                  ${roi ? roi.toFixed(1) : '-'}%
  Net gain over 5 years:      €${Nf(savings5)}
  Net gain over 10 years:     €${Nf(savings10)}

──────────────────────────────────────────────
  Generated by Automation ROI Calculator
`;

  const blob = new Blob([text], { type: 'text/plain' });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href = url; a.download = 'automation-roi-summary.txt';
  a.click();
  URL.revokeObjectURL(url);
}

function filterBen(btn) {
  document.querySelectorAll('.ben-fil').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
  const cat = btn.dataset.cat;
  document.querySelectorAll('.ben-card').forEach(c => {
    if (cat === 'all' || c.dataset.cat === cat) c.classList.remove('hidden');
    else c.classList.add('hidden');
  });
}

calc();
</script>
</body>
