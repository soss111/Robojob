<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Automation ROI Calculator</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  :root {
    --bg: #0c0d0f;
    --bg2: #141519;
    --bg3: #1b1d23;
    --bg4: #23252e;
    --border: rgba(255,255,255,0.07);
    --border2: rgba(255,255,255,0.12);
    --text: #f0f0ee;
    --text2: #9a9b9f;
    --text3: #5c5e65;
    --accent: #d4f04e;
    --accent2: #a8c73a;
    --accent-dim: rgba(212,240,78,0.1);
    --accent-dim2: rgba(212,240,78,0.06);
    --red: #ff5f5f;
    --red-dim: rgba(255,95,95,0.1);
    --green: #4effa0;
    --green-dim: rgba(78,255,160,0.08);
    --blue: #5b9cf6;
    --radius: 12px;
    --radius-lg: 18px;
    --font-display: 'Syne', sans-serif;
    --font-body: 'DM Sans', sans-serif;
    --font-mono: 'DM Mono', monospace;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    font-size: 14px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  /* ── NOISE OVERLAY ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
    opacity: 0.5;
  }

  /* ── LAYOUT ── */
  .app-wrapper {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px 80px;
  }

  /* ── HEADER ── */
  header {
    padding: 48px 0 40px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .header-left {}

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    color: var(--accent);
    letter-spacing: .15em;
    text-transform: uppercase;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .eyebrow::before {
    content: '';
    display: inline-block;
    width: 20px;
    height: 1px;
    background: var(--accent);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 800;
    color: var(--text);
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  h1 span { color: var(--accent); }

  .header-desc {
    font-size: 14px;
    color: var(--text2);
    margin-top: 10px;
    max-width: 480px;
    line-height: 1.7;
  }

  .preset-strip {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-self: flex-start;
    padding-top: 8px;
  }

  .preset-btn {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    padding: 7px 14px;
    border-radius: 100px;
    border: 1px solid var(--border2);
    background: var(--bg3);
    color: var(--text2);
    cursor: pointer;
    transition: all .2s ease;
    letter-spacing: .02em;
    white-space: nowrap;
  }

  .preset-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-dim2);
  }

  .preset-btn.active {
    border-color: var(--accent);
    color: var(--bg);
    background: var(--accent);
  }

  /* ── MAIN GRID ── */
  .main-grid {
    display: grid;
    grid-template-columns: 420px 1fr;
    gap: 24px;
    align-items: start;
  }

  @media (max-width: 960px) {
    .main-grid { grid-template-columns: 1fr; }
  }

  /* ── FORM PANEL ── */
  .form-panel {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .form-section {
    padding: 20px 24px;
    border-bottom: 1px solid var(--border);
  }

  .form-section:last-child { border-bottom: none; }

  .section-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--text3);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .field-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .field-grid.single { grid-template-columns: 1fr; }

  .field {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .field label {
    font-size: 11px;
    font-weight: 500;
    color: var(--text2);
    display: flex;
    align-items: center;
    gap: 5px;
    letter-spacing: .02em;
  }

  .field-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .field-wrap input {
    width: 100%;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 8px 40px 8px 12px;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    outline: none;
    transition: border-color .2s, background .2s;
    -moz-appearance: textfield;
    appearance: textfield;
  }

  .field-wrap input::-webkit-outer-spin-button,
  .field-wrap input::-webkit-inner-spin-button { -webkit-appearance: none; }

  .field-wrap input:focus {
    border-color: var(--accent);
    background: var(--bg4);
  }

  .field-wrap input:hover:not(:focus) {
    border-color: var(--border2);
  }

  .unit-badge {
    position: absolute;
    right: 10px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text3);
    pointer-events: none;
    letter-spacing: .04em;
  }

  /* tooltip */
  .tip-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--bg4);
    border: 1px solid var(--border2);
    font-size: 9px;
    color: var(--text3);
    cursor: help;
    position: relative;
    flex-shrink: 0;
  }

  .tip-icon:hover .tip-body {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .tip-body {
    position: absolute;
    left: 20px;
    top: -4px;
    width: 200px;
    background: var(--bg4);
    border: 1px solid var(--border2);
    border-radius: 8px;
    padding: 10px 12px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 400;
    color: var(--text2);
    line-height: 1.55;
    z-index: 20;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity .2s, transform .2s;
    pointer-events: none;
  }

  /* ── RESULTS PANEL ── */
  .results-panel {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* KPI bar */
  .kpi-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  @media (max-width: 700px) { .kpi-bar { grid-template-columns: 1fr 1fr; } }

  .kpi-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 18px 20px;
    position: relative;
    overflow: hidden;
    transition: border-color .2s;
  }

  .kpi-card.hero {
    border-color: var(--accent);
    background: var(--accent-dim2);
  }

  .kpi-card.hero::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--accent);
  }

  .kpi-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--text3);
    margin-bottom: 8px;
  }

  .kpi-value {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .kpi-card.hero .kpi-value { color: var(--accent); }

  .kpi-sub {
    font-size: 11px;
    color: var(--text3);
    margin-top: 5px;
    font-family: var(--font-mono);
  }

  /* breakdown card */
  .breakdown-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .card-header {
    padding: 16px 22px;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--text3);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .breakdown-rows { padding: 6px 0; }

  .brow {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 9px 22px;
    transition: background .15s;
  }

  .brow:hover { background: var(--bg3); }

  .brow .brow-label {
    font-size: 13px;
    color: var(--text2);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .brow .brow-label::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--text3);
    flex-shrink: 0;
  }

  .brow.positive .brow-label::before { background: var(--green); }
  .brow.negative .brow-label::before { background: var(--red); }

  .brow .brow-val {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
  }

  .brow.positive .brow-val { color: var(--green); }
  .brow.negative .brow-val { color: var(--red); }

  .brow-divider {
    height: 1px;
    background: var(--border);
    margin: 4px 22px;
  }

  .brow.total .brow-label {
    font-weight: 500;
    color: var(--text);
  }

  .brow.total .brow-val {
    color: var(--accent);
    font-size: 15px;
  }

  /* chart card */
  .chart-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .chart-body {
    padding: 20px 22px 16px;
  }

  .chart-legend {
    display: flex;
    gap: 20px;
    margin-bottom: 16px;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text3);
  }

  .legend-dot {
    width: 8px;
    height: 8px;
    border-radius: 2px;
  }

  .chart-canvas-wrap {
    position: relative;
    width: 100%;
    height: 220px;
  }

  /* long-term */
  .longterm-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .lt-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .lt-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text3);
    text-transform: uppercase;
    letter-spacing: .08em;
  }

  .lt-value {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: var(--green);
    letter-spacing: -0.02em;
  }

  .lt-year-badge {
    font-family: var(--font-mono);
    font-size: 32px;
    font-weight: 500;
    color: var(--border2);
    line-height: 1;
  }

  /* error state */
  .error-state {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 48px 32px;
    text-align: center;
  }

  .error-state .err-icon {
    font-size: 32px;
    margin-bottom: 12px;
    opacity: .4;
  }

  .error-state p {
    color: var(--text3);
    font-size: 13px;
    line-height: 1.7;
  }

  /* export */
  .export-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 10px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text2);
    cursor: pointer;
    transition: all .2s;
    letter-spacing: .04em;
    width: 100%;
  }

  .export-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-dim2);
  }

  .export-btn svg { flex-shrink: 0; }

  /* animate in */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .kpi-card, .breakdown-card, .chart-card, .lt-card {
    animation: fadeUp .4s ease both;
  }

  .kpi-card:nth-child(1) { animation-delay: .05s; }
  .kpi-card:nth-child(2) { animation-delay: .1s; }
  .kpi-card:nth-child(3) { animation-delay: .15s; }
  .kpi-card:nth-child(4) { animation-delay: .2s; }

  /* scrollbar */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--bg4); border-radius: 3px; }

  /* ── BENEFITS SECTION ── */
  .benefits-section {
    margin-top: 64px;
    padding-top: 48px;
    border-top: 1px solid var(--border);
  }

  .benefits-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }

  .benefits-title-block .eyebrow { margin-bottom: 8px; }

  .benefits-title-block h2 {
    font-family: var(--font-display);
    font-size: clamp(22px, 3vw, 34px);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.15;
    color: var(--text);
  }

  .benefits-title-block h2 span { color: var(--accent); }

  .ben-filters {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .ben-fil {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    padding: 6px 14px;
    border-radius: 100px;
    border: 1px solid var(--border2);
    background: transparent;
    color: var(--text3);
    cursor: pointer;
    transition: all .18s;
    letter-spacing: .03em;
    white-space: nowrap;
  }

  .ben-fil:hover { border-color: var(--border2); color: var(--text2); }

  .ben-fil.on {
    background: var(--text);
    color: var(--bg);
    border-color: var(--text);
  }

  .ben-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 14px;
  }

  .ben-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.1rem 1.25rem;
    transition: border-color .2s, transform .2s;
    animation: fadeUp .35s ease both;
  }

  .ben-card:hover {
    border-color: var(--border2);
    transform: translateY(-2px);
  }

  .ben-card.hidden { display: none; }

  .ben-card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: .8rem;
  }

  .ben-icon {
    width: 38px;
    height: 38px;
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ben-icon svg { width: 18px; height: 18px; }

  .ben-badge {
    display: inline-flex;
    align-items: center;
    padding: 3px 9px;
    border-radius: 100px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: .04em;
    white-space: nowrap;
  }

  .ben-title {
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 5px;
    line-height: 1.3;
  }

  .ben-body {
    font-size: 12px;
    color: var(--text2);
    line-height: 1.65;
  }

  .ben-stat {
    display: inline-block;
    margin-top: .65rem;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    padding: 3px 9px;
    border-radius: 6px;
    background: var(--bg3);
    border: 1px solid var(--border);
  }

  /* ── FORM IMPACT BOX ── */
  .impact-box {
    margin: 0;
    padding: 18px 24px 20px;
    background: var(--accent-dim2);
    border-top: 1px solid rgba(212,240,78,0.15);
  }

  .impact-box-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--accent2);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .impact-box-label::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  .impact-rows {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .impact-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .impact-row-label {
    font-size: 12px;
    color: var(--text2);
    line-height: 1.3;
  }

  .impact-row-val {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--accent);
    white-space: nowrap;
  }

  .impact-divider {
    height: 1px;
    background: rgba(212,240,78,0.1);
    margin: 4px 0;
  }

  .impact-row.total .impact-row-label {
    font-weight: 500;
    color: var(--text);
    font-size: 13px;
  }

  .impact-row.total .impact-row-val {
    font-size: 15px;
  }

  /* category accent colours (border-left on hover) */
  .ben-card[data-cat="financial"]:hover { border-color: rgba(78,255,160,0.3); }
  .ben-card[data-cat="ops"]:hover       { border-color: rgba(91,156,246,0.3); }
  .ben-card[data-cat="quality"]:hover   { border-color: rgba(175,169,236,0.3); }
  .ben-card[data-cat="safety"]:hover    { border-color: rgba(255,95,95,0.3); }
  .ben-card[data-cat="people"]:hover    { border-color: rgba(212,83,126,0.3); }
</style>
</head>
<body>
<div class="app-wrapper">

  <header>
    <div class="header-left">
      <div class="eyebrow">Financial Analysis Tool</div>
      <h1>Automation <span>ROI</span><br>Calculator</h1>
      <p class="header-desc">Evaluate the financial impact of robotics and automation investments. Real-time payback analysis for CNC, gantry, and bending cell solutions.</p>
    </div>
    <div class="preset-strip">
      <button class="preset-btn" id="preset-robojob" onclick="loadPreset('robojob')">CNC Robot (Robojob)</button>
      <button class="preset-btn" id="preset-cmz" onclick="loadPreset('cmz')">Gantry Loader (CMZ)</button>
      <button class="preset-btn" id="preset-trumpf" onclick="loadPreset('trumpf')">Bending Auto (TRUMPF)</button>
    </div>
  </header>

  <div class="main-grid">

    <!-- ── FORM ── -->
    <div class="form-panel">

      <div class="form-section">
        <div class="section-label">Investment</div>
        <div class="field-grid single">
          <div class="field">
            <label>
              Total investment cost
              <span class="tip-icon">?<span class="tip-body">Full upfront cost: robot, integration, tooling, safety fencing, installation, and commissioning.</span></span>
            </label>
            <div class="field-wrap">
              <input type="number" id="investment" value="120000" min="0" oninput="calc()">
              <span class="unit-badge">€</span>
            </div>
          </div>
        </div>
      </div>

      <div class="form-section">
        <div class="section-label">Labour</div>
        <div class="field-grid">
          <div class="field">
            <label>
              Operators replaced
